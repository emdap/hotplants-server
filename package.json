{
  "name": "hotplants-server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/app.js",
    "start:local": "tsx --env-file=.env src/app.ts",
    "dev": "pnpm generate-docs && tsx watch --env-file=.env src/app.ts",
    "build": "tsc && tsc-alias -f && pnpm generate-docs",
    "build:local": "pnpm build && mkdir -p dist/public && cp public/swagger.json \"$_\"",
    "generate-docs": "pnpm generate-graphql && pnpm generate-tsoa",
    "generate-graphql": "graphql-codegen --config src/graphqlConfig/codegen.ts",
    "generate-tsoa": "tsoa routes && tsoa spec",
    "generate-gbif-types": "npx openapi-typescript src/config/schemas/gbif-schema.json -o src/config/schemas/gbif.d.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@apollo/server": "^5.0.0",
    "@as-integrations/express5": "^1.1.2",
    "@tsoa/runtime": "^6.6.0",
    "@turf/turf": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "cors": "^2.8.5",
    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "express4": "link:@apollo/server/express4",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "jsdom": "^26.1.0",
    "mongodb": "^6.18.0",
    "openapi-fetch": "^0.14.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "wkt": "^0.1.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.7",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@graphql-tools/graphql-file-loader": "^8.1.2",
    "@graphql-tools/load": "^8.1.2",
    "@graphql-tools/schema": "^10.0.25",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/geojson": "^7946.0.16",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.1.0",
    "concurrently": "^9.2.0",
    "geojson": "^0.5.0",
    "openapi-typescript": "^7.8.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
