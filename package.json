    "dotenv": "^17.2.0",
    "express": "^5.1.0",
    "jsdom": "^26.1.0",
    "mongodb": "^6.18.0",
    "openapi-fetch": "^0.14.0",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.1.0",
    "openapi-typescript": "^7.8.0",
